# Môi trường chạy ứng dụng (development / production)
NODE_ENV=development
PORT=3000

# Thông tin kết nối Database PostgreSQL (Chỉ dùng cục bộ ở local)
DB_USER=sdl_user
DB_PASSWORD=sdl_password_123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sdl_db

# Mã bảo mật và thời hạn Token JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=24h

# Cấu hình cổng thanh toán PayOS
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# Cấu hình gửi mail qua Resend API
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Đường dẫn Client URL (đối với CORS)
FRONTEND_URL=http://localhost:5173

# Cấu hình hàng đợi và Cache Redis
# Ở Local dùng: redis://localhost:6379
# Ở Production dùng link Upstash: rediss://default:password@host:port
REDIS_URL=redis://localhost:6379
